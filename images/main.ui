  <property name="styleSheet">
   <string notr="true">* {
    font-family: "Microsoft YaHei", "Segoe UI", sans-serif;
    color: #21352b;
}
QWidget#centralwidget {
    background-color: #edf7f1;
}
QFrame#mainFrame {
    background-color: #f8fbf7;
    border: 1px solid #dcebe1;
    border-radius: 18px;
}
QLabel#lab_info {
    color: #395246;
    background-color: #e8f6ed;
    border: 1px solid #c8e8d2;
    border-radius: 14px;
    padding: 10px 18px;
    font-size: 14px;
}
QLabel#lab_logo {
    image: url(:/icon/wechat.png);
    background-color: #eaf8ee;
    border: 1px solid #c9ecd3;
    border-radius: 92px;
    padding: 18px;
}
QProgressBar {
    background-color: #e5efe8;
    border: 1px solid #d1e2d6;
    border-radius: 13px;
    color: #395246;
    font-size: 12px;
    text-align: center;
}
QProgressBar::chunk {
    background-color: #2fbf68;
    border-radius: 12px;
}
QLabel#lab_clean {
    color: #f8fbf7;
    background-color: #16a85a;
    border: 1px solid #149550;
    border-radius: 24px;
    font-size: 16px;
    font-weight: 600;
    padding: 0 34px;
}
QLabel#lab_clean:hover {
    background-color: #20b966;
    border-color: #18a75a;
}
QLabel#lab_config, QLabel#lab_close {
    color: #486256;
    background-color: #f1f7f3;
    border: 1px solid #d3e4d8;
    border-radius: 18px;
    font-size: 14px;
    padding: 0 16px;
}
QLabel#lab_config:hover, QLabel#lab_close:hover {
    color: #159452;
    background-color: #e8f6ed;
    border-color: #b9dfc5;
}
QLabel#lab_about {
    color: #6a7d72;
    font-size: 13px;
}</string>
