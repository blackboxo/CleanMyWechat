  <property name="styleSheet">
   <string notr="true">* {
    font-family: "Microsoft YaHei", "Segoe UI", sans-serif;
    color: #21352b;
}
QWidget#centralwidget {
    background-color: #edf7f1;
}
QFrame#mainFrame {
    background-color: #f8fbf7;
    border: 1px solid #dcebe1;
    border-radius: 18px;
}
QFrame#accountSection, QFrame#scopeSection, QFrame#deleteSection, QFrame#startupSection, QFrame#scheduleSection {
    background-color: #fbfdfb;
    border: 1px solid #dcebe1;
    border-radius: 14px;
}
QLabel#label {
    color: #6a7d72;
    font-size: 13px;
}
QLabel#lab_info {
    color: #395246;
    background-color: #e8f6ed;
    border: 1px solid #c8e8d2;
    border-radius: 14px;
    padding: 10px 18px;
    font-size: 14px;
}
QLabel.sectionTitle {
    color: #274135;
    font-size: 15px;
    font-weight: 600;
}
QLabel.sectionHint, QLabel#label_3, QLabel#label_auto_days {
    color: #6a7d72;
    font-size: 13px;
}
QComboBox, QLineEdit {
    background-color: #f1f7f3;
    border: 1px solid #d3e4d8;
    border-radius: 12px;
    min-height: 34px;
    padding: 4px 12px;
    font-size: 14px;
}
QComboBox:hover, QLineEdit:hover {
    border-color: #b9dfc5;
}
QComboBox::drop-down {
    width: 24px;
    border: 0;
}
QComboBox::down-arrow {
    image: url(:/icon/arrow-down.png);
}
QCheckBox {
    color: #31483d;
    font-size: 14px;
    spacing: 12px;
}
QCheckBox::indicator {
    width: 24px;
    height: 24px;
    border-radius: 5px;
}
QCheckBox::indicator:unchecked {
    background-color: #f8fbf7;
    border: 1px solid #b8d4c1;
}
QCheckBox::indicator:checked {
    background-color: #f8fbf7;
    border: 1px solid #149550;
    image: url(:/icon/复选1.svg);
}
QCheckBox#check_is_clean {
    color: #274135;
    background-color: #e8f6ed;
    border: 1px solid #c8e8d2;
    border-radius: 14px;
    padding: 12px 16px;
    font-size: 15px;
    font-weight: 600;
}
QCheckBox#check_is_clean::indicator {
    width: 24px;
    height: 24px;
}
QPushButton {
    min-height: 38px;
    padding: 0 18px;
    border-radius: 19px;
    font-size: 14px;
}
QPushButton#btn_file, QPushButton#btn_open_account {
    color: #486256;
    background-color: #f1f7f3;
    border: 1px solid #d3e4d8;
}
QPushButton#btn_file:hover, QPushButton#btn_open_account:hover {
    color: #159452;
    background-color: #e8f6ed;
    border-color: #b9dfc5;
}
QPushButton#btn_close {
    color: #f8fbf7;
    background-color: #16a85a;
    border: 1px solid #149550;
    font-weight: 600;
}
QPushButton#btn_close:hover {
    background-color: #20b966;
    border-color: #18a75a;
}</string>
